# Discord — https://discord.com/developers/applications
DISCORD_TOKEN=
CLIENT_ID=
# OAuth2 "Client Secret" (aba OAuth2) — login no site (Entrar com Discord). No portal, adicione Redirect:
#   http://127.0.0.1:3847/auth/discord/callback
# (ou o valor de OAUTH_REDIRECT_URI em produção)
DISCORD_CLIENT_SECRET=
# Opcional: assinatura das sessões do site (recomendado em produção)
# SESSION_SIGNING_SECRET=
# Opcional: se o bot tiver URL pública (HTTPS), defina o mesmo redirect que no Discord
# OAUTH_REDIRECT_URI=http://127.0.0.1:3847/auth/discord/callback
# Opcional: permitir colar ID manual no checkout mesmo com DISCORD_CLIENT_SECRET (só debug)
# ALLOW_MANUAL_DISCORD_ID=true

# Entrega no Roblox (script no Studio chama GET /roblox/pending-grants com Bearer)
# Gere uma string longa aleatória e use a MESMA em Roblox/EntregaSiteExterno.server.lua (CONFIG.API_SECRET).
# Em Render o ficheiro data/roblox-pending-grants.json pode apagar-se no deploy — use POST /roblox/requeue-from-stripe-session para re-enfileirar.
ROBLOX_API_SECRET=

# Registro rápido dos comandos slash neste servidor (opcional)
GUILD_ID=

# Canal de log de vendas (ID numérico do canal). Em Render/Fly/etc. o ficheiro data/guildConfig.json
# apaga-se no deploy — use isto para não depender de /setup vendas após cada restart.
# SALES_LOG_CHANNEL_ID=
# Opcional: log separado para Nitro/eventos (senão usa vendas)
# NITRO_LOG_CHANNEL_ID=

# Segredo para POST /webhooks/venda (Bearer ou body secret). Não confundir com STRIPE_WEBHOOK_SECRET (whsec_).
WEBHOOK_SECRET=

# Porta do servidor HTTP (webhook de vendas / Nitro)
PORT=3847

# Opcional: seu ID de usuário Discord para npm run test:webhook (sem argumento)
# Ative Modo desenvolvedor → perfil → Copiar ID
TEST_DISCORD_USER_ID=

# Simulação de compra pelo site (navegador): gere uma string longa e use a MESMA em Site/js/config.js
# em GEAR_CHECKOUT_DEMO.demoKey (enabled: true). Não use em produção pública sem HTTPS + rate limit.
DEMO_SALE_KEY=

# Origens CORS para POST /webhooks/demo-venda (separadas por vírgula). Vazio = lista padrão localhost.
# DEMO_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Stripe — Dashboard → Developers → API keys (sk_test_... / pk_test_...)
STRIPE_SECRET_KEY=
# Webhook: instale Stripe CLI e rode: stripe listen --forward-to localhost:3847/webhooks/stripe
# Cole o "Signing secret" (whsec_...) aqui:
STRIPE_WEBHOOK_SECRET=
# URL base do site (sucesso/cancelamento do Checkout). Live Server padrão:
SITE_BASE_URL=http://127.0.0.1:5500
